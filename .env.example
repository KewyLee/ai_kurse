PORT=3000
TELEGRAM_PERSONAL_USERNAME=your_username
TELEGRAM_CHANNEL_URL=https://t.me/your_channel
TELEGRAM_BOT_TOKEN=123456789:replace_with_real_bot_token
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_THREAD_ID=

# ── Google Sheets (необязательно) ──────────────────────────────────────────
# Если переменные не заданы — запись в таблицу просто пропускается,
# заявки всё равно уходят в Telegram.
#
# 1. Google Cloud Console → создать проект → включить "Google Sheets API"
# 2. Создать Service Account → Keys → Add Key → JSON (скачать)
# 3. Из JSON взять client_email и private_key
# 4. Открыть нужную таблицу и поделиться ею с client_email (права "Редактор")
# 5. ID таблицы — из её URL: docs.google.com/spreadsheets/d/<ЭТОТ_ID>/edit
#
# Важно: приватный ключ — одной строкой, переводы строк как \n (бэкслеш-n).
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
